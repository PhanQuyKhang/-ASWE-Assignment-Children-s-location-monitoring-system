# --- Node.js / NPM ---
# Bỏ qua node_modules ở tất cả các thư mục con (frontend, backend, root)
**/node_modules/

# Bỏ qua các file lock của npm (tùy chọn: nếu bạn muốn quản lý chặt chẽ phiên bản thì hãy giữ lại, nếu không thì bỏ qua)
# package-lock.json
# yarn.lock

# --- Môi trường (Security) ---
# Tuyệt đối không push file cấu hình mật khẩu/bí mật lên GitHub
.env
.env.local
.env.*.local

# --- Build files / Logs ---
# Các thư mục do hệ thống tự sinh ra sau khi build
dist/
build/
out/

# Các file log
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- IDE & OS ---
# Các thư mục cấu hình của trình soạn thảo (VS Code, WebStorm)
.vscode/
.idea/
*.swp

# Các file tạm của hệ điều hành
.DS_Store
Thumbs.db